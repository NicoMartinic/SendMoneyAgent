# ─────────────────────────────────────────────────────────────
#  Send Money Agent — Environment Variables
# ─────────────────────────────────────────────────────────────

# ── Model selection ──────────────────────────────────────────
# Common aliases:
#   gemini       -> gemini-2.5-flash
#   claude       -> litellm/anthropic/claude-sonnet-4-6
#   chatgpt      -> litellm/openai/gpt-5.4-mini
# Extra aliases:
#   gemini_pro | claude_opus | gpt54 | gpt54mini | gpt5
# Can also be overridden via --model CLI flag
SEND_MONEY_MODEL=gemini

# ── API Keys (only the key for your chosen model is required) ─

# Google / Gemini  →  https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic / Claude  →  https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI / ChatGPT  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
